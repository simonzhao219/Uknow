# 前端環境變數範例（複製為 .env.local 並填入實際值）。
# 讀取入口統一在 src/config.ts。

# --- PayUni 金流（必填）---
# 正式定期定額付款網址。刻意「無預設值」：缺此變數時付款會 fail-fast 擲錯，
# 杜絕沒設定的環境默默打到正式金流。部署環境務必設定。
VITE_PAYUNI_PAYMENT_URL=

# --- Supabase（選填，未設時退回 src/utils/supabase/info.tsx 的 autogenerated 值）---
# 設定以下任一以指向不同專案/環境（例如 staging）：
# VITE_SUPABASE_URL=https://<project>.supabase.co
# VITE_SUPABASE_ANON_KEY=<anon public key>
# VITE_SUPABASE_PROJECT_ID=<project ref>

# --- 對外分享連結網域（選填，未設時用目前站台 origin）---
# VITE_PUBLIC_APP_URL=https://uknow.tw
