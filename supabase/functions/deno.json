{
  "nodeModulesDir": "none",
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.window"]
  },
  "tasks": {
    "check": "deno check api/index.ts",
    "test": "deno test --allow-env --allow-net --allow-read"
  },
  "fmt": {
    "singleQuote": true,
    "lineWidth": 100
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
